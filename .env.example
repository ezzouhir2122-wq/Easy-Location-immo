# === CONFIGURATION APP ===
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-secret-key-here

# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === STRIPE ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === EMAIL (Resend ou SMTP) ===
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@easy-location-immo.fr

# === STOCKAGE DOCUMENTS ===
SUPABASE_STORAGE_BUCKET=documents-locataires

# === PDF GENERATION ===
# (géré via React-PDF côté client, pas de config serveur nécessaire)

# === NOTIFICATIONS ===
# (optionnel — notifications push ou SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+33...

# === MONITORING ===
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=info
